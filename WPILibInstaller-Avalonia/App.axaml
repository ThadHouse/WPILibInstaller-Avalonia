<Application
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:themes="using:Avalonia.Themes.Fluent"
    x:Class="WPILibInstaller.App"
    RequestedThemeVariant="Default">
    <Application.Styles>
        <Style Selector=":is(TopLevel)">
            <Setter Property="FontFamily" Value="fonts:Roboto#Roboto" />
        </Style>
        <themes:FluentTheme />
    </Application.Styles>
</Application>
